{
  "manifest_version": 3,
  "name": "Context Analyzer",
  "version": "0.6.0",
  "description": "Análise passiva de contexto e heurísticas de segurança em páginas web (MV3).",
  "icons": {
    "16": "icons/context-analyzer.png",
    "32": "icons/context-analyzer.png",
    "48": "icons/context-analyzer.png",
    "128": "icons/context-analyzer.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "webRequest",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Abrir Context Analyzer",
    "default_icon": {
      "16": "icons/context-analyzer.png",
      "32": "icons/context-analyzer.png",
      "48": "icons/context-analyzer.png",
      "128": "icons/context-analyzer.png"
    }
  }
}
